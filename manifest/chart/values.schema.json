{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "glassbox-mol-audit values",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "standard": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "digest": {
              "type": "string",
              "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"],
          "additionalProperties": true
        },
        "deep": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "digest": {
              "type": "string",
              "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"],
          "additionalProperties": true
        }
      },
      "required": ["tag", "pullPolicy"],
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "minLength": 1 },
        "runMode": { "type": "string", "enum": ["standard", "deep"] },
        "gcpRegion": { "type": "string" },
        "gcpLocation": { "type": "string" },
        "dataResidency": {
          "type": "string",
          "enum": ["strict", "project_local", "permissive"]
        },
        "egressMode": {
          "type": "string",
          "enum": ["STRICT_LOCAL", "ALLOW_GCP_ONLY", "ALLOW_EXTERNAL"]
        },
        "optionalAnalytics": { "type": "boolean" },
        "allowedEgressDomains": { "type": "string" },
        "regionTraceability": { "type": "boolean" },
        "timezone": { "type": "string", "minLength": 1 },
        "categoryId": { "type": "string" },
        "inputPath": { "type": "string", "minLength": 1 },
        "outputPath": { "type": "string", "minLength": 1 },
        "failClosed": { "type": "boolean" },
        "reproPackEnabled": { "type": "boolean" },
        "entitlementUrl": { "type": "string" },
        "entitlementAudience": { "type": "string" },
        "entitlementAuthMode": {
          "type": "string",
          "enum": [
            "",
            "auto",
            "google",
            "gcp",
            "idtoken",
            "principal",
            "none",
            "off",
            "disabled"
          ]
        },
        "entitlementTimeoutSec": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?$"
        },
        "TN_DISABLE_EXTERNAL_DATA": { "type": "string" },
        "TN_ENABLE_UQ": { "type": "string" },
        "TN_ENABLE_OT_FEATURES": { "type": "string" },
        "standardModeQuiet": { "type": "boolean" }
      },
      "required": [
        "projectId",
        "runMode",
        "inputPath",
        "outputPath",
        "failClosed",
        "reproPackEnabled",
        "entitlementUrl"
      ],
      "additionalProperties": true
    },
    "marketplace": {
      "type": "object",
      "properties": {
        "reportingSecret": { "type": "string" },
        "partnerSolutionLabel": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ubbagent": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "digest": {
              "type": "string",
              "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"],
          "additionalProperties": true
        },
        "localPort": {
          "type": "string",
          "pattern": "^[0-9]{2,5}$"
        },
        "metricName": { "type": "string" },
        "metricNameStandard": { "type": "string", "minLength": 1 },
        "metricNameDeep": { "type": "string", "minLength": 1 },
        "serviceName": { "type": "string", "minLength": 1 }
      },
      "required": [
        "enabled",
        "image",
        "localPort",
        "metricNameStandard",
        "metricNameDeep",
        "serviceName"
      ],
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": { "type": "object" },
        "limits": { "type": "object" }
      },
      "required": ["requests", "limits"],
      "additionalProperties": true
    },
    "storage": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["pvc", "gcs"] },
        "pvc": {
          "type": "object",
          "properties": {
            "storageClassName": { "type": "string" },
            "size": { "type": "string", "minLength": 2 }
          },
          "required": ["size"],
          "additionalProperties": true
        },
        "gcs": {
          "type": "object",
          "properties": {
            "bucket": { "type": "string" },
            "mountPath": { "type": "string" },
            "sidecarImage": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "required": ["type", "pvc", "gcs"],
      "additionalProperties": true
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      },
      "additionalProperties": true
    },
    "workloadIdentity": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "gcpServiceAccount": { "type": "string" }
      },
      "additionalProperties": true
    },
    "job": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "backoffLimit": { "type": "integer" },
        "ttlSecondsAfterFinished": { "type": "integer" },
        "activeDeadlineSeconds": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "apptest": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "digest": {
              "type": "string",
              "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"],
          "additionalProperties": true
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": { "type": "object" },
            "limits": { "type": "object" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "required": ["image", "config", "marketplace", "ubbagent", "resources", "storage"],
  "allOf": [
    {
      "if": {
        "properties": {
          "job": {
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "image": {
            "properties": {
              "repository": { "type": "string", "minLength": 1 }
            },
            "required": ["repository"]
          },
          "config": {
            "properties": {
              "categoryId": { "type": "string", "minLength": 1 },
              "entitlementUrl": { "type": "string", "minLength": 1 },
              "gcpRegion": { "type": "string", "minLength": 1 }
            },
            "required": ["categoryId", "entitlementUrl", "gcpRegion"]
          },
          "marketplace": {
            "properties": {
              "reportingSecret": { "type": "string", "minLength": 1 }
            },
            "required": ["reportingSecret"]
          },
          "ubbagent": {
            "properties": {
              "enabled": { "const": true },
              "image": {
                "properties": {
                  "repository": { "type": "string", "minLength": 1 }
                },
                "required": ["repository"]
              }
            },
            "required": ["enabled", "image"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "storage": {
            "properties": {
              "type": { "const": "gcs" }
            },
            "required": ["type"]
          }
        }
      },
      "then": {
        "properties": {
          "storage": {
            "properties": {
              "gcs": {
                "properties": {
                  "bucket": { "type": "string", "minLength": 1 }
                },
                "required": ["bucket"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ubbagent": {
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "ubbagent": {
            "properties": {
              "image": {
                "properties": {
                  "repository": { "type": "string", "minLength": 1 }
                },
                "required": ["repository"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "workloadIdentity": {
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "workloadIdentity": {
            "properties": {
              "gcpServiceAccount": { "type": "string", "minLength": 1 }
            },
            "required": ["gcpServiceAccount"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "apptest": {
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "apptest": {
            "properties": {
              "image": {
                "properties": {
                  "repository": { "type": "string", "minLength": 1 }
                },
                "required": ["repository"]
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
