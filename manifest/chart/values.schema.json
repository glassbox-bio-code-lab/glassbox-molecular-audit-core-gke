{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "glassbox-mol-audit values",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "standard": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "digest": {
              "type": "string",
              "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"],
          "additionalProperties": true
        },
        "deep": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "digest": {
              "type": "string",
              "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"],
          "additionalProperties": true
        }
      },
      "required": ["repository", "tag", "pullPolicy"],
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "minLength": 1 },
        "runMode": { "type": "string", "enum": ["standard", "deep"] },
        "categoryId": { "type": "string" },
        "inputPath": { "type": "string", "minLength": 1 },
        "outputPath": { "type": "string", "minLength": 1 },
        "failClosed": { "type": "boolean" },
        "reproPackEnabled": { "type": "boolean" },
        "entitlementUrl": { "type": "string", "minLength": 1 },
        "entitlementAuthMode": {
          "type": "string",
          "enum": [
            "",
            "auto",
            "google",
            "gcp",
            "idtoken",
            "principal",
            "none",
            "off",
            "disabled"
          ]
        },
        "entitlementTimeoutSec": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?$"
        }
      },
      "required": [
        "projectId",
        "runMode",
        "inputPath",
        "outputPath",
        "failClosed",
        "reproPackEnabled",
        "entitlementUrl"
      ],
      "additionalProperties": true
    },
    "marketplace": {
      "type": "object",
      "properties": {
        "reportingSecret": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ubbagent": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "digest": {
              "type": "string",
              "pattern": "^(|sha256:[a-fA-F0-9]{64})$"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"],
          "additionalProperties": true
        },
        "localPort": {
          "type": "string",
          "pattern": "^[0-9]{2,5}$"
        },
        "metricName": { "type": "string" },
        "metricNameStandard": { "type": "string", "minLength": 1 },
        "metricNameDeep": { "type": "string", "minLength": 1 },
        "serviceName": { "type": "string", "minLength": 1 }
      },
      "required": [
        "enabled",
        "image",
        "localPort",
        "metricNameStandard",
        "metricNameDeep",
        "serviceName"
      ],
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": { "type": "object" },
        "limits": { "type": "object" }
      },
      "required": ["requests", "limits"],
      "additionalProperties": true
    },
    "storage": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["pvc", "gcs"] },
        "pvc": {
          "type": "object",
          "properties": {
            "storageClassName": { "type": "string" },
            "size": { "type": "string", "minLength": 2 }
          },
          "required": ["size"],
          "additionalProperties": true
        },
        "gcs": {
          "type": "object",
          "properties": {
            "bucket": { "type": "string" },
            "mountPath": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "required": ["type", "pvc", "gcs"],
      "additionalProperties": true
    },
    "workloadIdentity": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "gcpServiceAccount": { "type": "string" }
      },
      "additionalProperties": true
    },
    "job": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "image",
    "config",
    "marketplace",
    "ubbagent",
    "resources",
    "storage"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "job": {
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "categoryId": { "type": "string", "minLength": 1 }
            },
            "required": ["categoryId"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "storage": {
            "properties": {
              "type": { "const": "gcs" }
            },
            "required": ["type"]
          }
        }
      },
      "then": {
        "properties": {
          "storage": {
            "properties": {
              "gcs": {
                "properties": {
                  "bucket": { "type": "string", "minLength": 1 }
                },
                "required": ["bucket"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "workloadIdentity": {
            "properties": {
              "enabled": { "const": true }
            },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "workloadIdentity": {
            "properties": {
              "gcpServiceAccount": { "type": "string", "minLength": 1 }
            },
            "required": ["gcpServiceAccount"]
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
